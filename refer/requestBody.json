{
    "order": "desc",
    "orderBy": "conversationStart",
    "paging": {
        "pageSize": 50,
        "pageNumber": 1
    },
    "interval": "2026-03-31T05:00:00.000Z/2026-04-01T05:00:00.000Z",
    "segmentFilters": [
        {
            "type": "or",
            "predicates": [
                {
                    "dimension": "direction",
                    "value": "inbound"
                },
                {
                    "dimension": "direction",
                    "value": "outbound"
                }
            ]
        }
    ],
    "conversationFilters": [
        {
            "type": "and",
            "predicates": [
                {
                    "type": "metric",
                    "metric": "tNotResponding",
                    "operator": "exists"
                }
            ]
        }
    ],
    "evaluationFilters": [],
    "surveyFilters": []
}